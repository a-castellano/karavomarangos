{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Limani image",
  "description": "Limani image definition.",
  "type": "object",
  "properties": {
    "name": {
      "description": "Name of the image.",
      "type": "string",
      "pattern": "^[a-z]+(_[a-z0-9]+)*$"
    },
    "base_image": {
      "description": "Name of the image.",
      "type": "string",
      "pattern": "^[a-z0-9\\-_]+((\\.[a-z0-9\\-_]+)*\\.[a-z]+\\/[a-z0-9\\-_]+\\/[a-z0-9\\-_]+)?(:[a-z0-9\\-_]+)?$"
    },
    "maintaniner": {
      "type": "object",
      "properties": {
        "name": {
          "description": "Name of the maintainer.",
          "type": "string"
        },
        "surname": {
          "description": "Surname of the maintainer.",
          "type": "string"
        },
        "e-mail": {
          "description": "e-mail of the maintainer.",
          "type": "string"
        }
      },
      "required": ["name", "surname", "e-mail"]
    },
    "required_repositories": {
      "description": "List of required repositories used by the image.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Name of the required repository.",
          "type": "string"
        },
        "apt_lines": {
          "description": "APT lines of the required repositories.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gpg_keyring": {
          "description": "GPG keyring file that will verify the repositories.",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the GPG keyring file.",
              "type": "string"
            },
            "content": {
              "description": "where is gpg key retrieved from.",
              "type": "object",
              "properties": {
                "type": {
                  "description": "where is gpg key retrieved from.",
                  "type": "string",
                  "enum": ["url", "key"]
                },
                "data": {
                  "description": "Urls or keys of the GPG keyring file.",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["type", "data"]
            }
          },
          "required": ["name", "content"]
        }
      },
      "required": ["apt_lines"]
    }
  },
  "packages": {
    "description": "List of packages that will be installed in the image.",
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "name": {
          "description": "Name of the package.",
          "type": "string"
        },
        "version": {
          "description": "Version of the package, this value can be ignored.",
          "type": "string"
        }
      },
      "required": ["name"]
    }
  },
  "extra_commands": {
    "description": "List of extra commands that will be executed after packages install",
    "type": "array",
    "items": { "type": "string" }
  },
  "user": {
    "description": "User that will be used to execute the image.",
    "type": "string"
  },
  "required": ["name", "base_image", "maintaniner"]
}
