{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Limani image",
  "description": "Limani image definition.",
  "type": "object",
  "properties": {
    "name": {
      "description": "Name of the image",
      "type": "string",
      "pattern": "^[a-z]+(_[a-z0-9]+)*$"
    },
    "base_image": {
      "description": "Name of the image",
      "type": "string",
      "pattern": "^[a-z0-9\\-_]+((\\.[a-z0-9\\-_]+)*\\.[a-z]+\\/[a-z0-9\\-_]+\\/[a-z0-9\\-_]+)?(:[a-z0-9\\-_]+)?$"
    },
    "maintaniner": {
      "type": "object",
      "properties": {
        "name": {
          "description": "Name of the maintainer",
          "type": "string"
        },
        "surname": {
          "description": "Surname of the maintainer",
          "type": "string"
        },
        "e-mail": {
          "description": "e-mail of the maintainer",
          "type": "string"
        }
      },
      "required": [
        "name",
        "surname",
        "e-mail"
      ]
    }
  },
  "required": [
    "name",
    "base_image",
    "maintaniner"
  ]
}
