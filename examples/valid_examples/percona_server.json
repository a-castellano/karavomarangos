{
  "name": "base_percona_server",
  "base_image": "harbor.windmaker.net/limani/base",
  "maintainer": {
    "name": "Álvaro",
    "surname": "Castellano Vela",
    "email": "alvaro@windmaker.net"
  },
  "packages": [
    {
      "name": "percona-telemetry-agent",
      "version": "1.0.7-1.noble"
    },
    {
      "name": "daedalus-project-mysql-utils",
      "version": "0.4-7"
    },
    {
      "name": "percona-server-server",
      "version": "8.4.7-7-1.noble"
    }
  ],
  "build_environment_variables": [
    {
      "name": "DEBIAN_FRONTEND",
      "value": "noninteractive"
    },
    {
      "name": "PERCONA_TELEMETRY_DISABLE",
      "value": "1"
    }
  ],
  "debconf_selections": [
    {
      "package": "percona-server-server",
      "question": "percona-server-server/root-pass",
      "type": "password",
      "value": "L3tm3_in"
    },
    {
      "package": "percona-server-server",
      "question": "percona-server-server/re-root-pass",
      "type": "password",
      "value": "L3tm3_in"
    },
    {
      "package": "percona-server-server",
      "question": "percona-server-server/default-auth-override",
      "type": "select",
      "value": "1"
    }
  ],
  "user": "mysql",
  "exposed_ports": [
    3306
  ],
  "command": [
    "/usr/sbin/mysqld",
    "--bind-address=0.0.0.0",
    "--skip_name_resolve"
  ]
}
