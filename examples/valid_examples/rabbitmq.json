{
  "name": "base_rabbitmq_server",
  "base_image": "harbor.windmaker.net/limani/base",
  "maintainer": {
    "name": "Álvaro",
    "surname": "Castellano Vela",
    "email": "alvaro@windmaker.net"
  },
  "packages": [
    {
      "name": "rabbitmq-server",
      "version": "3.12.1-1ubuntu1"
    }
  ],
  "user": "rabbitmq",
  "environment_variables": [
    {
      "name": "LANG",
      "value": "C.UTF-8"
    },
    {
      "name": "LANGUAGE",
      "value": "C.UTF-8"
    },
    {
      "name": "LC_ALL",
      "value": "C.UTF-8"
    }
  ],
  "exposed_ports": [
    4369,
    5671,
    5672,
    25672
  ],
  "command": [
    "rabbitmq-server"
  ],
  "copy": [
    {
      "source": "base_rabbitmq_server/files/rabbitmq.conf",
      "destination": "/tmp/rabbitmq.conf"
    },
    {
      "source": "base_rabbitmq_server/files/enabled_plugins",
      "destination": "/tmp/enabled_plugins"
    }
  ],
  "readme": {
    "description": "RabbitMQ server image with custom config and plugins. Ports 4369, 5671, 5672, 25672 exposed.",
    "aditiona_features": [
      "Custom rabbitmq.conf and enabled_plugins copied into image",
      "Runs as rabbitmq user with LANG/C.UTF-8"
    ]
  }
}
