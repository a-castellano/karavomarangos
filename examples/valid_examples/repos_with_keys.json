{
  "name": "base_golang_1_26",
  "base_image": "ubuntu:noble",
  "maintainer": {
    "name": "Álvaro",
    "surname": "Castellano Vela",
    "email": "alvaro@windmaker.net"
  },
  "required_repositories": {
    "name": "windmaker",
    "apt_lines": [
      "deb [signed-by=/etc/apt/keyrings/windmaker.gpg] http://packages.windmaker.net/ any main",
      "deb [arch=amd64 signed-by=/etc/apt/keyrings/windmaker.gpg] http://packages.windmaker.net/ noble main"
    ],
    "gpg_keyring": {
      "name": "windmaker",
      "content": {
        "type": "key",
        "data": [
          "C631127F87FA12D1",
          "F6BC817356A3D45E"
        ]
      }
    }
  },
  "packages": [
    {
      "name": "hugo",
      "version": "0.156.0"
    }
  ],
  "readme": {
    "description": "Example image with APT repositories and GPG keys provided by key ID (keyserver). Includes Hugo.",
    "additional_features": [
      "GPG keyring populated from keyserver by key ID",
      "Same package set as repos_with_urls but different key source"
    ]
  }
}
