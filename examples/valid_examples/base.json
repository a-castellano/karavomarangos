{
  "name": "base_golang_1_26",
  "base_image": "ubuntu:noble",
  "maintainer": {
    "name": "Álvaro",
    "surname": "Castellano Vela",
    "email": "alvaro@windmaker.net"
  },
  "required_repositories": {
    "name": "windmaker",
    "apt_lines": [
      "deb [signed-by=/etc/apt/keyrings/windmaker.gpg] http://packages.windmaker.net/ any main",
      "deb [arch=amd64 signed-by=/etc/apt/keyrings/windmaker.gpg] http://packages.windmaker.net/ noble main"
    ],
    "gpg_keyring": {
      "name": "windmaker",
      "content": {
        "type": "url",
        "data": ["http://packages.windmaker.net/WINDMAKER-GPG-KEY.pub"]
      }
    }
  },
  "readme": {
    "description": "This image is based on [base_deb_builder image](/base_deb_builder) and comes with Debian packaging utilities (golang 1.26 flavour).",
    "additional_features": [
      "Creates a symlink from `/usr/lib/go-1.26/bin/go` to `/usr/bin/go`",
      "Configures DEBEMAIL and DEBFULLNAME environment variables"
    ]
  }
}
